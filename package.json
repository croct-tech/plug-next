{
  "name": "@croct/plug-next",
  "version": "0.0.0-dev",
  "description": "React components and utilities to plug your Next.js applications into Croct.",
  "author": {
    "name": "Croct",
    "url": "https://croct.com",
    "email": "lib+plug-next@croct.com"
  },
  "keywords": [
    "croct",
    "personalization",
    "react",
    "next.js",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/croct-tech/plug-next.git"
  },
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    "./*": {
      "import": "./*.js",
      "require": "./*.cjs"
    }
  },
  "engines": {
    "node": ">=10"
  },
  "scripts": {
    "lint": "eslint 'src/**/*.ts' 'src/**/*.tsx'",
    "test": "jest -c jest.config.mjs --coverage",
    "validate": "tsc --noEmit",
    "build": "tsup",
    "postbuild": "./post-build.mjs"
  },
  "peerDependencies": {
    "next": "^13.0.0 || ^14.0.0 || ^15.0.0 || ^16.0.0",
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": false
    },
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    }
  },
  "dependencies": {
    "@croct/sdk": "^0.22.2",
    "@croct/plug": "^0.23.0",
    "@croct/plug-react": "^0.17.0",
    "@vercel/functions": "^3.5.0",
    "cookie": "^1.1.1",
    "path-to-regexp": "^8.4.2"
  },
  "devDependencies": {
    "next": "^16.0.0",
    "@babel/core": "^7.20.2",
    "@babel/preset-env": "^7.20.2",
    "@babel/preset-react": "^7.18.6",
    "@babel/preset-typescript": "^7.18.6",
    "@croct/eslint-plugin": "^0.8.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cookie": "^1.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/set-cookie-parser": "^2.4.10",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "babel-loader": "^10.1.1",
    "esbuild-fix-imports-plugin": "^1.0.23",
    "eslint": "^10.3.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "jest-extended": "^7.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "set-cookie-parser": "^3.1.0",
    "ts-node": "^10.8.1",
    "tsc-alias": "^1.8.8",
    "tsup": "^8.4.0",
    "typescript": "^5.4.5"
  },
  "files": [
    "**/*.js",
    "**/*.cjs",
    "**/*.mjs",
    "**/*.ts",
    "**/*.cts",
    "**/*.map"
  ]
}
